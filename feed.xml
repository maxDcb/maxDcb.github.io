---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <generator uri="https://jekyllrb.com/">Jekyll</generator>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/' | absolute_url }}</id>
  <title type="html">{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <author>
    <name>{{ site.author | xml_escape }}</name>
  </author>
  {% assign articles = site.pages | where: "article", true | sort: "date" | reverse %}
  {% for article in articles %}
  <entry>
    <title type="html">{{ article.title | xml_escape }}</title>
    <link href="{{ article.url | absolute_url }}" rel="alternate" type="text/html" />
    <published>{{ article.date | date_to_xmlschema }}</published>
    <updated>{{ article.date | date_to_xmlschema }}</updated>
    <id>{{ article.url | absolute_url }}</id>
    {% if article.description %}
    <summary type="html">{{ article.description | xml_escape }}</summary>
    {% endif %}
  </entry>
  {% endfor %}
</feed>
